<html lang="en">
<head>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }
        body {
            background-color: #1E2A3A; 
            color: #FFFFFF;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            width: 80%;
            max-width: 1200px;
        }
        header {
            text-align: center;
            margin-bottom: 5vh;
        }
        .logo {
            width: 20vw;
            max-width: 200px;
            margin: 0 auto 3vh;
        }
        .logo img {
            width: 100%;
            height: auto;
        }
        h1 {
            font-size: 3vw;
            margin-bottom: 1vh;
        }
        p {
            font-size: 1.2vw;
            margin-bottom: 3vh;
        }
        .buttons {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
        }
        .btn {
            background-color: #1DB954;
            color: #FFFFFF;
            border: none;
            padding: 1.5vh 3vw;
            font-size: 1vw;
            cursor: pointer;
            border-radius: 50vh;
            transition: all 0.3s ease;
            margin: 1vh;
            text-decoration: none;
            display: inline-block;
        }
        .btn:hover {
            background-color: #1ED760;
            transform: scale(1.05);
        }
        .btn-outline {
            background-color: transparent;
            border: 0.2vh solid #1DB954;
        }
        .btn-outline:hover {
            background-color: #1DB954;
        }
        @media (max-width: 768px) {
            .logo {
                width: 40vw;
            }
            h1 {
                font-size: 6vw;
            }
            p {
                font-size: 3vw;
            }
            .btn {
                font-size: 3vw;
                padding: 2vh 6vw;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="logo">
                <img src="/public/appImages/logo.jpeg" alt="MusicStream Logo">
            </div>
            <h1>Welcome to DTunes</h1>
            <p>The new Sportify!!</p>
            
        </header>
        <div class="buttons">
            <a href="/auth/signin" class="btn">Login as User</a>
            <a href="/auth/signup" class="btn btn-outline">Signup as User</a>
            <a href="/auth/artistSignin" class="btn">Login as Artist</a>
            <a href="/auth/registerArtist" class="btn btn-outline">Signup as Artist</a>
        </div>
    </div>
</body>
</html>