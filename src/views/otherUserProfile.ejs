<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/headTags.ejs") %>
    <link rel="stylesheet" href="/public/cssFiles/otherUserProfile.css">
</head>
<body>
    <div class="profile-container">
        <div class="upper-section">
            <div class="main-details">
                <div class="display-pic">
                    <img id="profile-image" src="<%= locals.userPopulated.profileImageUrl %>" alt="Profile Picture">
                </div>
                <div class="upper-section-info">
                    <div class="userName">
                        <h1 id="user-name"><%= locals.userPopulated.userName %></h1>
                    </div>
                    <div class="Role">
                        <h3 id="user-role"><%= locals.userPopulated.role %></h3>
                    </div>
                    <p id="user-email"><%= locals.userPopulated.emailId %></p>
                    <div class="friendRequestBtn">
                        <button id="friend-request-btn" class="friend-request-btn" data-userId="<%= locals.userPopulated._id %>">
                            Send Friend Request
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="section">
            <h2>Friends</h2>
            <div id="friends-container" class="item-container">
                <% locals.userPopulated.friends.forEach(friend => { %>
                    <div class="item">
                        <h3><%= friend.userName %></h3>
                        <p><%= friend.emailId %></p>
                        <p>Role: <%= friend.role %></p>
                    </div>
                <% }) %>
            </div>
        </div>

        <% if (locals.userPopulated.role === "Artist") { %>
            <div class="section">
                <h2>Published Music</h2>
                <div id="published-music-container" class="item-container"></div>
            </div>
        <% } %>
    </div>

    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
    <script src="/public/jsFunctions/otherUserPage.js"></script>
</body>
</html>