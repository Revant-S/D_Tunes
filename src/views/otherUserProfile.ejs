<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/headTags.ejs") %>
    <link rel="stylesheet" href="/public/cssFiles/otherUserProfile.css">
</head>
<body>
    <!-- profileImageUrl	"/public/appImages/headphone.jpeg"
userName	"Revant"
emailId	"revant.sinha@gmail.com"
role	"NormalUser"
likedSongs	[]
dislikedSongs	[]
musicPublished	[]
friends	[]
__v	0 -->

    <div class="profile-container">
        <div class="profile-header">
            <% console.log(locals.userPopulated); %>
            <img id="profile-image" src= "<%= locals.userPopulated.profileImageUrl %>" alt="Profile Picture">
            <h1 id="user-name">
                <%= locals.userPopulated.userName %>
            </h1>
            <p id="user-email">
                <%= locals.userPopulated.emailId %>
            </p>
            <p id="user-role">
                <%= locals.userPopulated.role %>
            </p>
            <button id="friend-request-btn" class="friend-request-btn"  data-userId="<%= locals.userPopulated._id %>">Send Friend Request</button>
        </div>
        
        <div class="section">
            <h2>Friends</h2>
            <div id="friends-container" class="item-container">
                <% locals.userPopulated.friends.forEach(friend => { %>
                    <div class="item">
                        <h3><%= friend.userName %></h3>
                        <p><%= friend.emailId %></p>
                        <p>Role: <%= friend.role %></p>
                    </div>
                <% }) %>
            </div>
        </div>
       <% if (locals.userPopulated.role === "Artist") { %>
        <div class="section">
            <h2>Published Music</h2>
            <div id="published-music-container" class="item-container"></div>
        </div>
       <% } %>
    </div>
    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
    <script src="/public/jsFunctions/otherUserPage.js"></script>
</body>
</html>