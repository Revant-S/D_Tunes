<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artist Registration</title>
    <style>
        body {
            color: #ffffff;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            background-image: url("/public/appImages/artistBack.webp");
            background-position: center;
            background-size: cover;
            background-repeat: no-repeat;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            background-color: rgb(30, 30, 30,0.5);
            padding: 5%;
            border-radius: 10px;
            width: 80%;
            max-width: 500px;
        }
        h1 {
            text-align: center;
            margin-bottom: 5%;
        }

        form {
            display: flex;
            flex-direction: column;
        }

        label {
            margin-bottom: 2%;
        }

        input {
            width: 100%;
            padding: 2%;
            margin-bottom: 5%;
            background-color: rgb(44, 44, 44, 1);
            border: none;
            border-radius: 5px;
            color: #ffffff;
        }

        button {
            background-color: #1db954;
            color: #ffffff;
            border: none;
            padding: 3%;
            border-radius: 5px;
            cursor: pointer;
            font-size: x-large;
        }

        button:hover {
            background-color: #1ed760;
        }

    </style>
</head>
<body>
    <div class="container">
        <h1>Sign In</h1>
        <form action="/auth/artistSignin" method="post">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" required>

            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>
            <button type="submit">Sign IN</button>
        </form>
    </div>
</body>
</html>