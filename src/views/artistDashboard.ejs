<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Artist Dashboard</title>
    <link rel="stylesheet" href="/public/cssFiles/aeristDash.css">
    <style>

    </style>

</head>

<body>
    <div class="dashboard">
        <%- include("./partials/artistNav.ejs") %>
            <div class="main-content">
                <div class="profile-summary">
                    <% console.log(locals.artistInDb.songsPublished.length); %>
                        <h1>Welcome, <span id="artistName">
                                <%= locals.artistInDb.artistName %>
                            </span></h1>
                        <p>Email: <span id="artistEmail">
                                <%= locals.artistInDb.email %>
                            </span></p>
                </div>
                <div class="stats-grid">
                    <div class="stat-card">
                        <h3>Songs Published</h3>
                        <p id="songCount">
                            <%= locals.artistInDb.songsPublished.length %>
                        </p>
                    </div>
                    <!-- <div class="stat-card">
                        <h3>Total Followers</h3>
                        <p id="followerCount">
                            <%= locals.artistInDb.followers.length %>
                        </p>
                    </div> -->
                </div>
                <div class="top-songs">
                    <h2>Songs Uploaded</h2>
                    <ul id="topSongsList">
                        <% if (locals.artistInDb.songsPublished.length !==0) { %>
                            <% locals.artistInDb.songsPublished.forEach((song, index)=> { %>
                                <li>
                                    <div class="song" data-song-url="<%= song.url %>" data-song-index="<%= index %>">
                                        <div class="songImage">
                                            <img src="<%= song.imageUrl %>" alt="">
                                        </div>
                                        <div class="info">
                                            <div class="songName">
                                                <%= song.trackName %>
                                            </div>
                                            <div class="likes">
                                                <div class="likesImg">
                                                    <img src="/public/appImages/like-svgrepo-com.svg" class="likeImg">
                                                </div>
                                                <div class="likeNumber">
                                                    <%= song.likes %>
                                                </div>
                                            </div>
                                        </div>
                                        <button class="playPauseBtn">Play</button>
                                        <div class="progress-container">
                                            <input type="range" class="progress-bar" value="0" min="0" max="100">
                                            <div class="progress-time">0:00 / 0:00</div>
                                        </div>
                                    </div>
                                </li>
                                <% }) %>
                                    <% } %>
                    </ul>
                </div>

                <audio id="audioPlayer"></audio>
                <audio id="audioPlayer"></audio>
            </div>
    </div>
    </div>
    <script src="/public/jsFunctions/artistDashBoard.js"></script>
</body>

</html>